# bakufu backend 環境変数テンプレート
# このファイルをコピーして backend/.env を作成してください: just env-init
# .env は .gitignore で除外済み。git に追加しないこと（gitleaks で二重防止）。

# ============================================================
# データディレクトリ
# ============================================================
# SQLite DB / WAL / 添付ファイルの格納先（絶対パス必須）
# コンテナ起動時: /app/data（Dockerfile の ENV で設定済み、変更不要）
# ネイティブ起動時: 任意のパスを指定（未設定時は OS デフォルト）
BAKUFU_DATA_DIR=/app/data

# ============================================================
# HTTP サーバ
# ============================================================
# バインドアドレス（threat-model.md §A3 / tech-stack.md §既定バインド: 127.0.0.1 を原則とする）
# ネイティブ起動時: 127.0.0.1（loopback のみ公開。変更禁止）
# docker-compose 起動時: docker-compose.yml の environment セクションが 0.0.0.0 に上書きする
#   → ホスト公開は ports の "127.0.0.1:8000:8000" で制御するため、コンテナ内 0.0.0.0 は安全
#   → この .env の値は docker-compose 起動では参照されない（environment セクションが優先）
BAKUFU_BIND_HOST=127.0.0.1
# バインドポート
BAKUFU_BIND_PORT=8000

# ============================================================
# CORS
# ============================================================
# 許可する Origin のカンマ区切りリスト（未設定時: http://localhost:5173 のみ）
# 複数 Origin を許可する場合: BAKUFU_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
BAKUFU_ALLOWED_ORIGINS=http://localhost:5173

# ============================================================
# Reverse Proxy
# ============================================================
# 外部公開時（Caddy / Nginx 等の前段）: true に設定
# ローカル開発: false（既定値）
BAKUFU_TRUST_PROXY=false

# ============================================================
# LLM プロバイダ設定（必須）
# ============================================================
# 使用するプロバイダを選択: anthropic / openai
BAKUFU_LLM_PROVIDER=anthropic

# --- Anthropic ---
# BAKUFU_LLM_PROVIDER=anthropic の場合に必須
BAKUFU_ANTHROPIC_API_KEY=your-anthropic-api-key-here
# モデル名（省略時: claude-3-5-sonnet-20241022）
# BAKUFU_ANTHROPIC_MODEL_NAME=claude-3-5-sonnet-20241022

# --- OpenAI ---
# BAKUFU_LLM_PROVIDER=openai の場合に必須
# BAKUFU_OPENAI_API_KEY=your-openai-api-key-here
# モデル名（省略時: gpt-4o-mini）
# BAKUFU_OPENAI_MODEL_NAME=gpt-4o-mini

# ============================================================
# LLM 共通設定
# ============================================================
# API タイムアウト（秒）
# BAKUFU_LLM_TIMEOUT_SECONDS=30.0
