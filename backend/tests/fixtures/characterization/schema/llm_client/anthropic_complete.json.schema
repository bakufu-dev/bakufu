{
  "_meta": {"schema_for": "anthropic_complete_success.json", "created_at": "2026-05-01T00:00:00Z"},
  "type": "object",
  "required": ["id", "type", "role", "content", "model", "stop_reason", "usage"],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string", "const": "message"},
    "role": {"type": "string", "const": "assistant"},
    "content": {"type": "array", "minItems": 1},
    "model": {"type": "string"},
    "stop_reason": {"type": "string", "observed_values": ["end_turn", "max_tokens"]},
    "usage": {"type": "object", "required": ["input_tokens", "output_tokens"]}
  },
  "statistics": {
    "stop_reason_frequencies": {"end_turn": 0.95, "max_tokens": 0.05},
    "content_length_mean": 150,
    "content_length_stddev": 80
  }
}
